# Quorum — Environment Configuration
# Copy to .env and adjust values
# IMPORTANT: ห้าม commit .env — มีข้อมูลลับ

# ─────────────────── Backend (Rust) ─────────────────────────────

DATABASE_URL=postgres://postgres:postgres@localhost:5432/quorum
AI_SIDECAR_URL=http://127.0.0.1:8765
BIND_ADDR=0.0.0.0:8080
FRONTEND_DIR=../frontend/dist

# Timing settings (seconds)
WATCH_INTERVAL_SECS=60       # Trigger/stop check frequency (lower = faster reaction)
DEEP_INTERVAL_SECS=900       # Deep analysis frequency (lower = more AI work)
NO_PLAN_COOLDOWN_SECS=3600   # Cooldown after a plan is rejected

# ─────────────────── Authentication ─────────────────────────────

# JWT secret - if unset, a new random value is generated on every restart (sessions expire)
# Generate with: openssl rand -hex 32
JWT_SECRET=replace_me_with_32_byte_hex_secret

# Default password for admin (owner@quorum.local) - change it in the profile page
# If unset, a random one will be generated and printed in the startup log
ADMIN_PASSWORD=change_me_on_first_login

# ─────────────────── AI Layer (Python) ──────────────────────────

AI_HOST=127.0.0.1
AI_PORT=8765

# Release the LLM from RAM/VRAM after idle (lowest memory usage when idle)
# "120s" = frees ~9GB between deep runs · "0" = release immediately (most memory-friendly, but reloads often)
# "-1" or "24h" = keep it in RAM all the time (fastest, but uses memory continuously)
OLLAMA_KEEP_ALIVE=120s

# News API (optional) - real news from Finnhub or NewsAPI
# FINNHUB_API_KEY=your_finnhub_key
# NEWSAPI_KEY=your_newsapi_key

# ─────────────────── Cloud AI Judge (optional) ───────────────────
# API keys for cloud AI judge - configure via UI (Settings -> AI Judge)
# Do not put them here; they are stored in PostgreSQL through the backend safely
#
# Supported providers: Anthropic Claude, OpenAI, Groq, OpenRouter, custom base_url
# A/B test in Settings -> "Compare local/cloud"

# ─────────────────── Bitkub (live trading) ───────────────────────
# Bitkub API key/secret - set via the UI (top-right modal), not here
# Stored in PostgreSQL through the backend, never returned by the API
